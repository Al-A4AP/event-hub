generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  CUSTOMER
  ORGANIZER
  ADMIN
}

enum EventStatus {
  DRAFT
  PUBLISHED
  CANCELLED
  COMPLETED
}

enum TransactionStatus {
  PENDING
  WAITING_PAYMENT
  PAID
  CANCELLED
  REJECTED
}

model User {
  id           Int      @id @default(autoincrement())
  name         String
  email        String   @unique
  password     String
  role         Role     @default(CUSTOMER)
  referralCode String   @unique @default(cuid())
  referredBy   String?
  avatar       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  events       Event[]       @relation("OrganizerEvents")
  transactions Transaction[]
  reviews      Review[]
  points       UserPoint[]
  vouchers     UserVoucher[]

  @@map("users")
}

model Event {
  id             Int         @id @default(autoincrement())
  organizerId    Int
  organizer      User        @relation("OrganizerEvents", fields: [organizerId], references: [id])
  title          String
  slug           String      @unique
  description    String      @db.Text
  category       String
  location       String
  startDate      DateTime
  endDate        DateTime
  price          Decimal     @default(0) @db.Decimal(12, 2)
  isFree         Boolean     @default(false)
  availableSeats Int
  totalSeats     Int
  imageUrl       String?
  status         EventStatus @default(DRAFT)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  ticketTypes  TicketType[]
  transactions Transaction[]
  reviews      Review[]
  vouchers     Voucher[]

  @@map("events")
}

model TicketType {
  id             Int     @id @default(autoincrement())
  eventId        Int
  event          Event   @relation(fields: [eventId], references: [id])
  name           String
  price          Decimal @db.Decimal(12, 2)
  quota          Int
  availableSeats Int
  description    String?

  @@map("ticket_types")
}

model Transaction {
  id             Int               @id @default(autoincrement())
  userId         Int
  user           User              @relation(fields: [userId], references: [id])
  eventId        Int
  event          Event             @relation(fields: [eventId], references: [id])
  ticketTypeId   Int?
  quantity       Int
  totalPrice     Decimal           @db.Decimal(12, 2)
  pointsUsed     Int               @default(0)
  voucherCode    String?
  discountAmount Decimal           @default(0) @db.Decimal(12, 2)
  finalPrice     Decimal           @db.Decimal(12, 2)
  status         TransactionStatus @default(PENDING)
  paymentProof   String?
  expiredAt      DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@map("transactions")
}

model Review {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  eventId   Int
  event     Event    @relation(fields: [eventId], references: [id])
  rating    Int
  comment   String?  @db.Text
  createdAt DateTime @default(now())

  @@unique([userId, eventId])
  @@map("reviews")
}

model Voucher {
  id              Int           @id @default(autoincrement())
  eventId         Int
  event           Event         @relation(fields: [eventId], references: [id])
  code            String        @unique
  discountPercent Int?
  discountAmount  Decimal?      @db.Decimal(12, 2)
  maxUsage        Int
  usedCount       Int           @default(0)
  startDate       DateTime?
  expiresAt       DateTime
  createdAt       DateTime      @default(now())
  userVouchers    UserVoucher[]

  @@map("vouchers")
}

model UserVoucher {
  id        Int       @id @default(autoincrement())
  userId    Int
  user      User      @relation(fields: [userId], references: [id])
  voucherId Int
  voucher   Voucher   @relation(fields: [voucherId], references: [id])
  isUsed    Boolean   @default(false)
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@unique([userId, voucherId])
  @@map("user_vouchers")
}

model UserPoint {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  points    Int
  source    String
  isUsed    Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("user_points")
}
